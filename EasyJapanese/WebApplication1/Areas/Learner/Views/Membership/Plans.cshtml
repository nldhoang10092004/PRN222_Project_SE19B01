@model IEnumerable<CoreLibrary.Data.Entities.SubscriptionPlan>
@{
    ViewData["Title"] = "Gói Học Tập";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .hj-banner-pricing {
            background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
            padding: 80px 0 60px;
            color: #fff;
            text-align: center;
        }
        .pricing-title {
            font-family: 'Outfit', sans-serif;
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 20px;
        }
        .pricing-subtitle {
            color: rgba(255, 255, 255, 0.8);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }
        .pricing-card {
            background: #fff;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .pricing-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        }
        .pricing-card.popular {
            border: 2px solid var(--color-primary);
        }
        .popular-badge {
            position: absolute;
            top: 0;
            right: 0;
            background: var(--color-primary);
            color: #fff;
            padding: 8px 24px;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom-left-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .plan-name {
            font-family: 'Outfit', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }
        .plan-price {
            font-family: 'Outfit', sans-serif;
            font-size: 3rem;
            font-weight: 800;
            color: var(--color-primary);
            margin-bottom: 5px;
        }
        .plan-duration {
            color: #888;
            font-weight: 500;
            margin-bottom: 30px;
        }
        .plan-features {
            list-style: none;
            padding: 0;
            margin: 0 0 40px 0;
            flex-grow: 1;
        }
        .plan-features li {
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
            color: #555;
            display: flex;
            align-items: center;
        }
        .plan-features li:last-child {
            border-bottom: none;
        }
        .plan-features li i {
            color: #198754;
            font-size: 1.2rem;
            margin-right: 12px;
        }
        .btn-select-plan {
            background-color: transparent;
            color: var(--color-primary);
            border: 2px solid var(--color-primary);
            padding: 14px 24px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            display: block;
            text-align: center;
            transition: all 0.3s ease;
        }
        .btn-select-plan:hover {
            background-color: var(--color-primary);
            color: #fff;
        }
        .pricing-card.popular .btn-select-plan {
            background-color: var(--color-primary);
            color: #fff;
        }
        .pricing-card.popular .btn-select-plan:hover {
            background-color: #d13a40;
            border-color: #d13a40;
        }
    </style>
}

<div class="hj-banner-pricing">
    <div class="container">
        <h1 class="pricing-title">Mở khoá toàn bộ tính năng</h1>
        <p class="pricing-subtitle">Chọn gói học phù hợp để truy cập không giới hạn vào khoá học N5-N1, bài test xếp lớp, thẻ ghi nhớ (flashcard) và theo dõi lộ trình học tập cá nhân.</p>
    </div>
</div>

<div class="container" style="margin-top: -40px; padding-bottom: 100px; position: relative; z-index: 10;">
    <div class="row justify-content-center g-4">
        @if (Model != null && Model.Any())
        {
            var index = 0;
            foreach (var plan in Model)
            {
                bool isPopular = index == 1 || (Model.Count() == 1); // Highlight middle one
                
                <div class="col-lg-4 col-md-6">
                    <div class="pricing-card @(isPopular ? "popular" : "")">
                        @if (isPopular)
                        {
                            <div class="popular-badge">Phổ biến nhất</div>
                        }
                        <div class="plan-name">@plan.PlanName</div>
                        <div class="plan-price">@plan.Price.ToString("N0")<span style="font-size: 1.5rem;">đ</span></div>
                        <div class="plan-duration">/ @plan.DurationDays ngày</div>

                        <ul class="plan-features">
                            <li><i class="bi bi-check-circle-fill"></i> Truy cập toàn bộ khoá học (N5 - N1)</li>
                            <li><i class="bi bi-check-circle-fill"></i> Không giới hạn bài test xếp lớp</li>
                            <li><i class="bi bi-check-circle-fill"></i> Tính năng ôn tập Flashcard (SRT)</li>
                            <li><i class="bi bi-check-circle-fill"></i> Theo dõi lộ trình học tập</li>
                            <li><i class="bi bi-check-circle-fill"></i> Không chứa quảng cáo</li>
                        </ul>

                        <a asp-area="Learner" asp-controller="Membership" asp-action="Checkout" asp-route-planId="@plan.PlanId" class="btn-select-plan">
                            Chọn gói này
                        </a>
                    </div>
                </div>
                index++;
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h3>Hiện tại không có gói học nào khả dụng.</h3>
            </div>
        }
    </div>
</div>
