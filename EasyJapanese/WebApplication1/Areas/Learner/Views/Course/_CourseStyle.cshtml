        position: relative;
    }

    .course-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .course-body {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .badge-level {
        display: inline-block;
