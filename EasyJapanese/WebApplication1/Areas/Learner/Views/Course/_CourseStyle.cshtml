<style>
    .course-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .course-back-link {
        color: #6c757d;
        text-decoration: none;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    
    .course-back-link:hover {
        color: var(--color-primary);
    }

    .course-title {
        font-family: 'Outfit', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--color-text);
        margin: 0;
    }

    /* Video Player Mockup */
    .video-container {
        width: 100%;
        aspect-ratio: 16 / 9;
        background-color: #212529;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }

    .play-button {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: 3px solid var(--color-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(200, 16, 46, 0.1);
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
    }

    .play-button:hover {
        transform: scale(1.1);
        background: rgba(200, 16, 46, 0.2);
    }

    .play-button::after {
        content: "";
        display: block;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 10px 0 10px 16px;
        border-color: transparent transparent transparent var(--color-primary);
        margin-left: 6px;
    }

    /* Custom Tabs */
    .course-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        background: #fff;
        padding: 0.5rem;
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
        justify-content: space-between;
    }

    .course-tab {
        flex: 1;
        text-align: center;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #6c757d;
        text-decoration: none;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border: 1px solid transparent;
        cursor: pointer;
    }

    .course-tab:hover {
        background: #f8f9fa;
        color: var(--color-text);
    }

    .course-tab.active {
        background: #da3e44;
        color: #fff;
        box-shadow: 0 4px 12px rgba(218, 62, 68, 0.3);
    }
    
    .course-tab.active i {
        color: #fff;
    }

    .course-tab i {
        font-size: 1.1rem;
    }

