    .kanji-section {
        padding: 2rem;
    }
    
    .kanji-section-title {
        color: #0d6efd;
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .kanji-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .kanji-card {
        background: #f8f9fc;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 2rem 1rem;
        text-align: center;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .kanji-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.08);
        border-color: #d1d5db;
    }

    .kanji-char {
        font-size: 4rem;
        line-height: 1;
        margin-bottom: 1rem;
        color: #212529;
        font-family: "Yu Mincho", "MS Mincho", serif;
    }

    .kanji-meaning {
        font-size: 0.9rem;
        color: #6c757d;
    }

    /* Course List & Cards Styles */
    .course-list-title {
        font-family: 'Outfit', sans-serif;
        font-size: 2.25rem;
        font-weight: 800;
        color: #333;
    }

