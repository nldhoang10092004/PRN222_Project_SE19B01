@{
    ViewData["Title"] = "Hi Japan! - Nền tảng học tiếng Nhật #1";
}

<!-- Hero -->
<section class="hj-hero">
    <div class="container">
        <div class="row align-items-center gy-5">
            <div class="col-lg-6">
                <span class="hj-eyebrow">NỀN TẢNG HỌC TIẾNG NHẬT #1</span>
                <h1 class="hj-hero-title">
                    Chinh phục tiếng Nhật <span class="text-primary">dễ dàng hơn</span> bao giờ hết
                </h1>
                <p class="hj-hero-sub">
                    Hệ thống học thông minh với video bài giảng chuẩn 4K, giáo trình độc quyền và lộ trình cá nhân hóa.
                    Cam kết đậu JLPT trong 6 tháng.
                </p>
                <div class="hj-hero-cta">
                    <a href="/Register" class="btn btn-primary btn-lg">Học thử miễn phí ngay</a>
                    <a href="/learn/PlacementTest" class="btn btn-outline-primary btn-lg">Test trình độ</a>
                </div>
                <div class="hj-hero-proof">
                    <div class="hj-avatars">
                        <img src="https://i.pravatar.cc/64?img=1" alt="user" />
                        <img src="https://i.pravatar.cc/64?img=2" alt="user" />
                        <img src="https://i.pravatar.cc/64?img=3" alt="user" />
                    </div>
                    <span class="hj-proof-text">+10,000 học viên đã đăng ký</span>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hj-hero-image-wrap">
                    <img class="hj-hero-image"
                         src="https://images.unsplash.com/photo-1492571350019-22de08371fd3?w=1200&q=80"
                         alt="Học tiếng Nhật" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="hj-section" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="hj-section-title">Tại sao chọn Hi Japan!?</h2>
            <p class="hj-section-sub">Công nghệ AI kết hợp phương pháp giảng dạy chuẩn Nhật Bản</p>
        </div>
        <div class="row gy-4">
            <div class="col-md-4">
                <div class="hj-feature-card">
                    <div class="hj-feature-icon">▶</div>
                    <h3 class="hj-feature-title">Video Chuẩn 4K</h3>
                    <p class="hj-feature-desc">Bài giảng quay bởi giáo viên bản xứ, hình ảnh sắc nét đến từng chi tiết, hỗ trợ học mọi lúc mọi nơi.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hj-feature-card">
                    <div class="hj-feature-icon">📘</div>
                    <h3 class="hj-feature-title">Giáo Trình Độc Quyền</h3>
                    <p class="hj-feature-desc">Hệ thống giáo trình biên soạn riêng, bám sát khung JLPT N5 - N1, tích hợp văn hóa Nhật Bản.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hj-feature-card">
                    <div class="hj-feature-icon">📊</div>
                    <h3 class="hj-feature-title">Theo Dõi Tiến Độ</h3>
                    <p class="hj-feature-desc">Dashboard cá nhân hóa theo dõi tiến độ học tập, gợi ý bài học và nhắc nhở lịch ôn tập tự động.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Roadmap -->
<section class="hj-section hj-section--alt" id="roadmap">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="hj-section-title">Lộ trình học tập rõ ràng</h2>
            <p class="hj-section-sub">Đi từ con số 0 đến chinh phục JLPT mơ ước</p>
        </div>
        <div class="row gy-4">
            <div class="col-md-4">
                <div class="hj-level-card">
                    <span class="hj-level-badge">N5</span>
                    <h3 class="hj-level-title">Sơ cấp</h3>
                    <p class="hj-level-desc">800 từ vựng, 100 chữ Kanji cơ bản. Giao tiếp đời thường đơn giản.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hj-level-card">
                    <span class="hj-level-badge">N4</span>
                    <h3 class="hj-level-title">Trung cấp</h3>
                    <p class="hj-level-desc">1,500 từ vựng, 300 chữ Kanji. Đọc hiểu văn bản đơn giản và hội thoại hàng ngày.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hj-level-card">
                    <span class="hj-level-badge">N3</span>
                    <h3 class="hj-level-title">Trung - Cao cấp</h3>
                    <p class="hj-level-desc">3,750 từ vựng, 650 chữ Kanji. Đọc báo, xem tin tức và giao tiếp công việc.</p>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a href="#" class="btn btn-primary btn-lg">Xem chi tiết lộ trình</a>
        </div>
    </div>
</section>

<!-- Pricing -->
<section class="hj-section" id="pricing">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="hj-section-title">Đăng ký Membership</h2>
            <p class="hj-section-sub">Chọn gói phù hợp với mục tiêu của bạn</p>
        </div>
        <div class="row gy-4 justify-content-center">
            <div class="col-md-5">
                <div class="hj-price-card">
                    <h3 class="hj-price-name">6 Tháng</h3>
                    <div class="hj-price-amount">899.000đ<span class="hj-price-period">/6 tháng</span></div>
                    <ul class="hj-price-features">
                        <li>✔ Truy cập toàn bộ khóa học N5 - N3</li>
                        <li>✔ Video bài giảng chuẩn 4K</li>
                        <li>✔ Giáo trình PDF độc quyền</li>
                        <li>✔ Hỗ trợ qua cộng đồng</li>
                    </ul>
                    <a href="/Register" class="btn btn-outline-primary w-100">Đăng ký ngay</a>
                </div>
            </div>
            <div class="col-md-5">
                <div class="hj-price-card hj-price-card--featured">
                    <span class="hj-price-badge">BÁN CHẠY NHẤT</span>
                    <h3 class="hj-price-name">1 Năm</h3>
                    <div class="hj-price-amount">1.990.000đ<span class="hj-price-period">/năm</span></div>
                    <ul class="hj-price-features">
                        <li>✔ Tất cả quyền lợi gói 6 tháng</li>
                        <li>✔ Mentor 1-on-1 hàng tháng</li>
                        <li>✔ Lộ trình cá nhân hóa bằng AI</li>
                        <li>✔ Cam kết đậu JLPT hoàn tiền 100%</li>
                    </ul>
                    <a href="/Register" class="btn btn-primary w-100">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Final CTA -->
<section class="hj-final-cta">
    <div class="container text-center">
        <h2 class="hj-final-cta-title">Sẵn sàng để thay đổi tương lai của bạn?</h2>
        <p class="hj-final-cta-sub">Tham gia cùng hơn 10,000 học viên đang chinh phục tiếng Nhật mỗi ngày.</p>
        <a href="/Register" class="btn btn-primary btn-lg">Tạo tài khoản miễn phí</a>
    </div>
</section>
