@model CoreLibrary.Data.Entities.Student
@{
    ViewData["Title"] = "Thông tin tài khoản - Hi Japan!";
}

@section Styles {
    <style>
        .card-premium {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        .btn-primary-warm {
            background: var(--color-primary, #C8102E);
            color: #fff;
            border: none;
        }
        .btn-primary-warm:hover {
            background: #a30d25;
            color: #fff;
        }
        .fw-500 { font-weight: 500; }
        .fw-600 { font-weight: 600; }
        .fade-in-up {
            animation: fadeInUp 0.5s ease-out;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}

<div class="py-5" style="background-color: var(--color-bg, #f8f9fa);">
    <div class="container">
        <div class="row g-4 fade-in-up">
            
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="card-premium p-4 sticky-top" style="top: 100px;">
                    <div class="text-center mb-4">
                        <div class="position-relative d-inline-block">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" class="rounded-circle border border-4 border-white shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Profile Picture">
                            }
                            else
                            {
                                <div class="rounded-circle border border-4 border-white shadow-sm d-flex align-items-center justify-content-center bg-secondary text-white" style="width: 150px; height: 150px; font-size: 4rem; line-height: 1; padding-top: 5px;">
                                    @((Model.FullName ?? Model.StudentNavigation.Email).Substring(0, 1).ToUpper())
                                </div>
                            }
                            <button class="btn btn-primary-warm rounded-circle position-absolute d-flex align-items-center justify-content-center p-0" style="width: 36px; height: 36px; bottom: 5px; right: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                                <i class="bi bi-camera-fill"></i>
                            </button>
                        </div>
                        <h4 class="mt-3 mb-1">@(Model.FullName ?? "Chưa cập nhật")</h4>
                        <p class="text-muted small">@Model.StudentNavigation.Email</p>
                    </div>

                    <div class="list-group list-group-flush" style="margin: 0 -24px;">
                        <a href="#" class="list-group-item list-group-item-action bg-transparent border-0 px-4 py-3 active fw-600 text-primary" style="border-left: 4px solid var(--color-primary, #C8102E) !important;"><i class="bi bi-person me-3"></i>Thông tin cá nhân</a>
                        <a href="#" class="list-group-item list-group-item-action bg-transparent border-0 px-4 py-3 text-muted"><i class="bi bi-shield-lock me-3"></i>Bảo mật</a>
                        <a href="#" class="list-group-item list-group-item-action bg-transparent border-0 px-4 py-3 text-muted"><i class="bi bi-credit-card me-3"></i>Lịch sử thanh toán</a>
                        <a href="#" class="list-group-item list-group-item-action bg-transparent border-0 px-4 py-3 text-muted"><i class="bi bi-bell me-3"></i>Thông báo</a>
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="col-lg-9">
                <div class="card-premium p-4 p-md-5">
                    <h3 class="mb-4">Thông tin cá nhân</h3>
                    
                    <form method="post" action="/learn/Profile/Update">
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-500">Họ và tên</label>
                                <input type="text" name="FullName" class="form-control p-3 bg-light border-0" value="@Model.FullName" style="border-radius: 8px;">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-500">Email</label>
                                <input type="email" class="form-control p-3 bg-light border-0 text-muted" value="@Model.StudentNavigation.Email" readonly style="border-radius: 8px;">
                                <small class="text-muted d-block mt-1">Email không thể thay đổi.</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-500">Số điện thoại</label>
                                <input type="tel" name="PhoneNumber" class="form-control p-3 bg-light border-0" value="@Model.PhoneNumber" placeholder="Thêm số điện thoại" style="border-radius: 8px;">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-500">Mục tiêu JLPT</label>
                                <select class="form-select p-3 bg-light border-0" style="border-radius: 8px;" disabled>
                                    <option value="N5" selected="@(ViewBag.JlptLevel == "N5")">N5</option>
                                    <option value="N4" selected="@(ViewBag.JlptLevel == "N4")">N4</option>
                                    <option value="N3" selected="@(ViewBag.JlptLevel == "N3")">N3</option>
                                    <option value="N2" selected="@(ViewBag.JlptLevel == "N2")">N2</option>
                                    <option value="N1" selected="@(ViewBag.JlptLevel == "N1")">N1</option>
                                    <option value="Cơ bản" selected="@(ViewBag.JlptLevel == "Cơ bản")">Cơ bản</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-muted fw-500">Giới thiệu bản thân</label>
                                <textarea name="Bio" class="form-control p-3 bg-light border-0" rows="4" placeholder="Một vài dòng giới thiệu về bạn..." style="border-radius: 8px;"></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 pt-3 border-top mt-5">
                            <button type="button" class="btn btn-light px-4 rounded-pill">Hủy</button>
                            <button type="submit" class="btn btn-primary-warm px-5 rounded-pill">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
