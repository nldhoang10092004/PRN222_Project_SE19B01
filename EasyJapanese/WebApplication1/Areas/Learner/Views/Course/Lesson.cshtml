@model CoreLibrary.Data.Entities.Lesson
@{
    ViewData["Title"] = Model?.Title ?? "Nội dung bài học";
}

@section Styles {
    @await Html.PartialAsync("_CourseStyle")
    <style>
        .tab-content-panel {
            display: none;
            animation: fadeIn 0.3s ease-in-out;
        }
        .tab-content-panel.active {
            display: block;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .kanji-section-title {
            color: #0d6efd;
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }
    </style>
}

@if (Model != null)
{
<div class="hj-content container" style="max-width: 1000px; margin: 0 auto; padding-top: 2rem; padding-bottom: 5rem;">
    <!-- Header -->
    <a href="/learn/Course/Detail/@Model.CourseId" class="course-back-link mb-3">
        &larr; Quay lại khóa học
    </a>
    
    <div class="course-header mb-4 d-flex justify-content-between align-items-center">
        <h1 class="course-title m-0">@Model.Title</h1>
        <button class="btn btn-danger px-4 py-2" style="border-radius: 50px; font-weight: 600; background-color: #e64a51; border: none;">
            Làm Quiz Cuối Bài <i class="bi bi-patch-check ms-1"></i>
        </button>
    </div>

    <!-- Video Player -->
    <div class="video-container shadow-sm mb-4" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000; border-radius: 12px;">
        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            <iframe src="@Model.VideoUrl" style="position: absolute; top:0; left:0; width: 100%; height: 100%; border: none;" allowfullscreen></iframe>
        }
        else
        {
            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-white" style="position: absolute; top:0; left:0;">
                <div class="text-center">
                    <i class="bi bi-play-circle" style="font-size: 4rem; color: #e64a51; cursor: pointer;"></i>
                    <p class="mt-3 text-muted">Video bài giảng đang được cập nhật</p>
                </div>
            </div>
        }
    </div>

    <!-- Content -->
    <div class="hj-card p-4 shadow-sm border-0 mb-4" style="border-radius: 16px;">
        <h4 class="kanji-section-title">Nội dung tóm tắt</h4>
        <div class="p-3 bg-light rounded" style="font-size: 1.1rem; line-height: 1.6;">
            @Html.Raw(Model.Content?.Replace("\n", "<br/>") ?? "Chưa có nội dung.")
        </div>
    </div>

    <!-- Sub Tabs (Mock data retained for UI purposes) -->
    <div class="course-tabs mb-4">
        <div class="course-tab active" data-target="tab-kanji" style="cursor: pointer;"><i class="bi bi-translate me-2"></i>Kanji</div>
        <div class="course-tab" data-target="tab-grammar" style="cursor: pointer;"><i class="bi bi-journal-text me-2"></i>Ngữ pháp</div>
        <div class="course-tab" data-target="tab-reading" style="cursor: pointer;"><i class="bi bi-book me-2"></i>Đọc</div>
        <div class="course-tab" data-target="tab-listening" style="cursor: pointer;"><i class="bi bi-headphones me-2"></i>Nghe</div>
    </div>

    <!-- Tab Contents -->
    <div class="hj-card p-4 shadow-sm border-0" style="border-radius: 16px;">
        
        <!-- Kanji Content -->
        <div id="tab-kanji" class="tab-content-panel active">
            <h4 class="kanji-section-title">Kanji (Minh họa)</h4>
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="p-4 border rounded text-center bg-light" style="border-color: #eaeaea !important;">
                        <h1 class="display-3 mb-0" style="font-family: 'Yu Mincho', 'MS Mincho', serif; color: #212529;">私</h1>
                        <p class="text-muted mt-2 mb-0" style="font-size: 0.9rem;">Watashi - Tôi</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-4 border rounded text-center bg-light" style="border-color: #eaeaea !important;">
                        <h1 class="display-3 mb-0" style="font-family: 'Yu Mincho', 'MS Mincho', serif; color: #212529;">人</h1>
                        <p class="text-muted mt-2 mb-0" style="font-size: 0.9rem;">Hito / Jin - Người</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grammar Content -->
        <div id="tab-grammar" class="tab-content-panel">
            <h4 class="kanji-section-title">Ngữ pháp (Minh họa)</h4>
            <div class="list-group list-group-flush">
                <div class="list-group-item px-0 py-3 border-bottom">
                    <h5 class="mb-2" style="font-weight: 700; color: #333;">1. N1 は N2 です</h5>
                    <p class="text-muted mb-0">N1 là N2. Dùng để khẳng định.</p>
                </div>
            </div>
        </div>

        <!-- Reading Content -->
        <div id="tab-reading" class="tab-content-panel">
            <h4 class="kanji-section-title">Đọc hiểu (Minh họa)</h4>
            <div class="bg-light p-4 rounded mb-4 border" style="border-color: #eaeaea !important;">
                <p class="lead mb-0" style="line-height: 2; font-size: 1.1rem; color: #333;">
                    はじめまして。<br>わたしは マイク・ミラーです。
                </p>
            </div>
        </div>

        <!-- Listening Content -->
        <div id="tab-listening" class="tab-content-panel">
            <h4 class="kanji-section-title">Nghe hiểu (Minh họa)</h4>
            <div class="d-flex align-items-center bg-light p-4 rounded border">
                <button class="btn btn-primary rounded-circle p-3 me-4" style="width: 60px; height: 60px;"><i class="bi bi-play-fill fs-4"></i></button>
                <div>
                    <h5 class="mb-1" style="font-weight: 700;">Audio Track 1</h5>
                    <div class="text-muted small">00:00 / 01:25</div>
                </div>
            </div>
        </div>

    </div>
</div>
}
else
{
    <div class="container py-5 text-center">
        <h2>Không tìm thấy bài học!</h2>
        <a href="/learn/Course" class="btn btn-primary mt-3">Quay lại danh sách khóa học</a>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabs = document.querySelectorAll('.course-tab');
            var panels = document.querySelectorAll('.tab-content-panel');

            tabs.forEach(function(tab) {
                tab.addEventListener('click', function() {
                    var targetId = this.getAttribute('data-target');
                    
                    tabs.forEach(function(t) { t.classList.remove('active'); });
                    panels.forEach(function(p) { p.classList.remove('active'); });
                    
                    this.classList.add('active');
                    var targetPanel = document.getElementById(targetId);
                    if(targetPanel) targetPanel.classList.add('active');
                });
            });
        });
    </script>
}
