@model CoreWeb.Areas.Learner.Models.LearnerDashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Hi Japan!";
    Layout = null;

    var hasMembership = Model.HasActiveMembership;
    var hasTest = Model.HasCompletedPlacementTest;
    var hasStartedLearning = Model.ContinueLesson != null;

    // Greeting based on time (server-side approximation using UTC+7)
    var hour = DateTime.UtcNow.AddHours(7).Hour;
    var greeting = hour < 12 ? "Chào buổi sáng" : hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";

    // Circular progress for JLPT ring
    int pctGoal = 0;
    if (Model.JlptGoal != null && Model.JlptGoal.TotalPoints > 0)
        pctGoal = (int)Math.Round(100.0 * Model.JlptGoal.Score / Model.JlptGoal.TotalPoints);
    var dashOffset = 283 - (int)(283 * pctGoal / 100.0);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true">
    @await Html.PartialAsync("_DashboardStyle")

</head>
<body>
    @await Html.PartialAsync("_LearnerHeader")
    
    <!-- ═══ BANNER ═══ -->
    <div class="hj-banner">
        <div class="hj-banner-kanji">
            @if (!hasMembership)
            {
                <text>学</text>
            }
            else if (!hasTest)
            {

                <text>試</text>
            }
            else
            {

                <text>日</text>
            }
        </div>
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <p class="hj-banner-jp mb-0">
                        @if (!hasMembership)
                        {
                            <text>ようこそ — Chào mừng đến Hi Japan!</text>
                        }
                        else if (!hasTest)
                        {

                            <text>あと一歩 — Chỉ còn một bước nữa!</text>
                        }
                        else if (!hasStartedLearning)
                        {

                            <text>結果が出ました — Kết quả đã có!</text>
                        }
                        else
                        {

                            <text>@(hour < 12 ? "おはようございます" : hour < 18 ? "こんにちは" : "こんばんは")</text>
                        }
                    </p>
                    <h1 class="hj-banner-title">
                        @greeting, @Model.FullName! 👋
                    </h1>
                    <p class="hj-banner-sub">
                        @if (!hasMembership)
                        {
                            <text>Bắt đầu hành trình tiếng Nhật của bạn — chọn gói học để mở khoá toàn bộ nội dung.</text>
                        }
                        else if (!hasTest)
                        {
                            <text>Làm bài test xếp lớp để được gợi ý lộ trình học phù hợp với bạn.</text>
                        }
                        else if (!hasStartedLearning)
                        {
                            <text>Trình độ của bạn đã được xác định. Bắt đầu bài học đầu tiên ngay nhé!</text>
                        }
                        else
                        {
                            <text>Hôm nay bạn muốn học gì? Bạn đang ở chuỗi <strong>@Model.StreakDays ngày</strong> liên tiếp — hãy giữ vững phong độ!</text>
                        }
                    </p>
                </div>
                <div class="col-md-4 text-end d-none d-md-block">
                    @if (hasMembership && hasStartedLearning && Model.StreakDays > 0)
                    {
                        <div class="hj-streak-badge d-inline-flex">
                            <span class="hj-streak-num">🔥 @Model.StreakDays</span>
                            <span class="hj-streak-lbl">ngày liên tiếp</span>
                        </div>
                    }
                    else
                    {
                        <i class="bi @(!hasMembership ? "bi-lock" : !hasTest ? "bi-bullseye" : "bi-flag-fill") text-white opacity-25" style="font-size: 80px;"></i>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="hj-content">
        <div class="container">

            @* ────────────────────────────────────────────────────────
           TRẠNG THÁI 1 — Chưa có membership
           ──────────────────────────────────────────────────────── *@
            @if (!hasMembership)
            {
                <!-- Upgrade CTA -->
                <div class="hj-upgrade-card p-4 mb-5 d-flex align-items-center justify-content-between flex-wrap gap-3 fade-in">
                    <div>
                        <span class="hj-upgrade-tag">Chưa kích hoạt</span>
                        <h4 class="fw-bold text-white mb-1" style="font-family:'Outfit',sans-serif;">Mở khoá toàn bộ khoá học N5 → N1</h4>
                        <p class="mb-0" style="color:rgba(255,255,255,.82);font-size:14px;">Flashcard · Quiz · Bài test xếp lớp · Không giới hạn truy cập</p>
                    </div>
                    <a asp-area="Learner" asp-controller="Membership" asp-action="Plans" class="btn-hj-light">
                        Xem gói học →
                    </a>
                </div>

                <!-- Free vs Locked -->
                <h5 class="hj-section-title fade-in delay-1">Bạn có thể làm gì ngay bây giờ?</h5>
                <div class="row g-4 mb-5 fade-in delay-1">
                    <div class="col-md-6">
                        <div class="hj-free-card p-4 h-100">
                            <div class="text-success small fw-600 mb-2">Miễn phí</div>
                            <h5 class="text-success fw-bold mb-2" style="font-family:'Outfit',sans-serif;">Xem thử khoá học</h5>
                            <p class="text-muted small mb-3">Duyệt danh sách bài học và xem demo nội dung trước khi đăng ký.</p>
                            <a asp-area="Learner" asp-controller="Course" asp-action="Index" class="btn-hj-outline" style="font-size:13px;padding:7px 18px;">Xem khoá học →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="hj-free-card p-4 h-100">
                            <div class="text-success small fw-600 mb-2">Miễn phí · Không cần membership</div>
                            <h5 class="text-success fw-bold mb-2" style="font-family:'Outfit',sans-serif;">Test xếp lớp</h5>
                            <p class="text-muted small mb-3">40 câu, ~20 phút. Xác định trình độ N5–N1 ngay bây giờ — kết quả sẽ gợi ý lộ trình học phù hợp.</p>
                            <a href="/learn/PlacementTest" class="btn-hj-primary" style="font-size:13px;padding:7px 18px;">Làm bài test →</a>
                        </div>
                    </div>
                </div>

                <!-- Pricing plans -->
                @if (Model.AvailablePlans != null && Model.AvailablePlans.Any())
                {
                    <h5 class="hj-section-title fade-in delay-2">Chọn gói học phù hợp</h5>
                    <div class="row g-4 fade-in delay-2">
                        @foreach (var plan in Model.AvailablePlans)
                        {
                            <div class="col-md-4">
                                <div class="hj-plan-card p-4 text-center h-100 bg-white">
                                    <div class="fw-700 mb-2" style="font-family:'Outfit',sans-serif;">@plan.PlanName</div>
                                    <div class="mb-1" style="font-size:24px;font-weight:800;color:var(--color-primary);font-family:'Outfit',sans-serif;">
                                        @plan.Price.ToString("N0")đ
                                    </div>
                                    <div class="text-muted small mb-4">/ @plan.DurationDays ngày</div>
                                    <a asp-area="Learner" asp-controller="Membership" asp-action="Checkout"
                                       asp-route-planId="@plan.PlanId" class="btn-hj-outline w-100 text-center d-block">
                                        Chọn gói
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            }

            @* ────────────────────────────────────────────────────────
           TRẠNG THÁI 2 — Có membership, CHƯA làm placement test
           ──────────────────────────────────────────────────────── *@
            else if (hasMembership && !hasTest)
            {
                <div class="hj-placement-card p-5 text-center fade-in">
                    <div style="font-size:42px;" class="mb-3">🎯</div>
                    <h3 class="fw-bold mb-3" style="font-family:'Outfit',sans-serif;">Bạn muốn học ở trình độ nào?</h3>
                    <p class="text-muted mb-4" style="max-width:480px;margin:0 auto;">
                        Làm bài test xếp lớp để nhận gợi ý trình độ phù hợp (N5–N1) và lộ trình học cá nhân hoá,
                        hoặc bắt đầu ngay từ mức Cơ bản nếu bạn hoàn toàn mới.
                    </p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a asp-area="Learner" asp-controller="PlacementTest" asp-action="Start" class="btn-hj-primary">
                            <i class="bi bi-pencil-square me-2"></i>Làm bài test xếp lớp
                        </a>
                        <a asp-area="Learner" asp-controller="Course" asp-action="StartBasic" class="btn-hj-outline">
                            Bắt đầu từ Cơ bản
                        </a>
                    </div>
                </div>

                <!-- Info cards below -->
                <div class="row g-4 mt-4 fade-in delay-1">
                    <div class="col-md-4">
                        <div class="hj-card p-4 text-center h-100">
                            <div style="font-size:28px;" class="mb-2">📋</div>
                            <div class="fw-700 mb-1" style="font-family:'Outfit',sans-serif;">~15 phút</div>
                            <div class="text-muted small">Thời gian làm bài test</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="hj-card p-4 text-center h-100">
                            <div style="font-size:28px;" class="mb-2">🎯</div>
                            <div class="fw-700 mb-1" style="font-family:'Outfit',sans-serif;">N5 → N1</div>
                            <div class="text-muted small">Trình độ được xét đến</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="hj-card p-4 text-center h-100">
                            <div style="font-size:28px;" class="mb-2">🗺️</div>
                            <div class="fw-700 mb-1" style="font-family:'Outfit',sans-serif;">Lộ trình riêng</div>
                            <div class="text-muted small">Cá nhân hoá theo kết quả</div>
                        </div>
                    </div>
                </div>
            }

            @* ────────────────────────────────────────────────────────
           TRẠNG THÁI 3 — Đã test, CHƯA bắt đầu học
           ──────────────────────────────────────────────────────── *@
            else if (hasMembership && hasTest && !hasStartedLearning)
            {
                <div class="hj-result-card p-4 p-md-5 mb-5 fade-in">
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div class="hj-hanko">合格</div>
                        <div>
                            <h4 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif;">Kết quả xếp lớp của bạn đã có!</h4>
                            <p class="text-muted mb-0" style="font-size:14px;">
                                Điểm test: <strong>@Model.JlptGoal?.Score/@Model.JlptGoal?.TotalPoints</strong> ·
                                Trình độ đề xuất: <strong>@Model.JlptGoal?.RecommendedLevelName</strong>
                            </p>
                        </div>
                    </div>

                    <div class="row align-items-center g-4">
                        <div class="col-md-3 text-center">
                            <div class="position-relative d-inline-block">
                                <svg width="150" height="150" viewBox="0 0 100 100">
                                    <circle cx="50" cy="50" r="45" fill="none" stroke="#E8E0D5" stroke-width="8" />
                                    <circle cx="50" cy="50" r="45" fill="none" stroke="var(--color-primary)" stroke-width="8"
                                            stroke-dasharray="283" stroke-dashoffset="@dashOffset"
                                            stroke-linecap="round" transform="rotate(-90 50 50)" />
                                </svg>
                                <div class="position-absolute top-50 start-50 translate-middle text-center">
                                    <div style="font-size:24px;font-weight:800;font-family:'Outfit',sans-serif;">@Model.JlptGoal?.RecommendedLevelName</div>
                                    <small class="text-muted">Đề xuất</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-9">
                            <p class="text-muted mb-4" style="font-size:15px;line-height:1.7;">
                                Trình độ <strong>@Model.JlptGoal?.RecommendedLevelName</strong> phù hợp với năng lực hiện tại của bạn.
                                Bắt đầu ngay bài học đầu tiên để giữ động lực — <span style="color:var(--color-primary);font-weight:700;">頑張ってください！</span>
                            </p>
                            <div class="d-flex gap-3 flex-wrap">
                                <a asp-area="Learner" asp-controller="Course" asp-action="Index"
                                   asp-route-level="@Model.JlptGoal?.RecommendedLevelName" class="btn-hj-primary">
                                    <i class="bi bi-play-fill me-1"></i>Bắt đầu học ngay
                                </a>
                                <a asp-area="Learner" asp-controller="PlacementTest" asp-action="Start" class="btn-hj-outline" style="font-size:13px;">
                                    Làm lại bài test
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ────────────────────────────────────────────────────────
           TRẠNG THÁI 4 — Dashboard đầy đủ
           ──────────────────────────────────────────────────────── *@
            else
            {
                <div class="row g-4">

                    <!-- ── LEFT COLUMN ── -->
                    <div class="col-lg-8">

                        <!-- Continue learning -->
                        <h5 class="hj-section-title fade-in">Tiếp tục học</h5>
                        <div class="hj-continue-card mb-5 fade-in delay-1">
                            <div class="row g-0">
                                <div class="col-md-4">
                                    <div class="hj-continue-thumb">日</div>
                                </div>
                                <div class="col-md-8 p-4">
                                    <span class="badge rounded-pill mb-2" style="background:rgba(200,16,46,.12);color:var(--color-primary);font-weight:600;">
                                        @Model.ContinueLesson!.LevelName
                                    </span>
                                    <h5 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif;">@Model.ContinueLesson!.LessonTitle</h5>
                                    <p class="text-muted small mb-4">@Model.ContinueLesson!.CourseTitle</p>

                                    <div class="d-flex align-items-center gap-3 mb-4">
                                        <div class="hj-progress flex-grow-1">
                                            <div class="hj-progress-bar" style="width:@(Model.ContinueLesson!.PercentComplete)%"></div>
                                        </div>
                                        <span style="font-size:13px;font-weight:600;color:var(--color-primary);min-width:36px;">
                                            @(Model.ContinueLesson!.PercentComplete)%
                                        </span>
                                    </div>

                                    <a asp-area="Learner" asp-controller="Lesson" asp-action="Watch"
                                       asp-route-id="@Model.ContinueLesson!.LessonId" class="btn-hj-primary">
                                        <i class="bi bi-play-fill me-1"></i>Tiếp tục ngay
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Stats -->
                        <h5 class="hj-section-title fade-in delay-1">Thống kê học tập</h5>
                        <div class="row g-4 fade-in delay-2">
                            <div class="col-md-4">
                                <div class="hj-stat-card p-4 text-center bg-white">
                                    <div class="hj-stat-num" style="color:var(--color-navy);">@Model.Stats.CoursesEnrolled</div>
                                    <div class="hj-stat-lbl">Khoá học đang theo</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="hj-stat-card p-4 text-center bg-white">
                                    <div class="hj-stat-num" style="color:#d4a017;">@Model.Stats.FlashcardsLearned</div>
                                    <div class="hj-stat-lbl">Flashcard đã tạo</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="hj-stat-card p-4 text-center bg-white">
                                    <div class="hj-stat-num" style="color:#198754;">@Model.Stats.LessonsCompleted</div>
                                    <div class="hj-stat-lbl">Bài học hoàn thành</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── RIGHT COLUMN ── -->
                    <div class="col-lg-4">

                        <!-- JLPT Goal ring -->
                        <div class="hj-goal-card p-4 bg-white mb-4 fade-in delay-3">
                            <div class="hj-goal-title">Trình độ hiện tại</div>
                            <div class="text-center mb-3">
                                <div class="position-relative d-inline-block">
                                    <svg width="150" height="150" viewBox="0 0 100 100">
                                        <circle cx="50" cy="50" r="45" fill="none" stroke="#E8E0D5" stroke-width="8" />
                                        <circle cx="50" cy="50" r="45" fill="none" stroke="var(--color-primary)" stroke-width="8"
                                                stroke-dasharray="283" stroke-dashoffset="@dashOffset"
                                                stroke-linecap="round" transform="rotate(-90 50 50)" />
                                    </svg>
                                    <div class="position-absolute top-50 start-50 translate-middle text-center">
                                        <div style="font-size:24px;font-weight:800;font-family:'Outfit',sans-serif;">@Model.JlptGoal?.RecommendedLevelName</div>
                                        <small class="text-muted">Đề xuất</small>
                                    </div>
                                </div>
                            </div>
                            <p class="text-center hj-goal-note mb-4">
                                Kết quả test đầu vào: <strong>@Model.JlptGoal?.Score/@Model.JlptGoal?.TotalPoints điểm</strong>
                            </p>
                            <a asp-area="Learner" asp-controller="Course" asp-action="Index"
                               asp-route-level="@Model.JlptGoal?.RecommendedLevelName"
                               class="btn-hj-outline w-100 d-block text-center">
                                Xem khoá học phù hợp
                            </a>
                        </div>

                        <!-- Flashcard review -->
                        <div class="hj-review-card p-4 bg-white fade-in delay-4">
                            <div class="hj-review-title">Flashcard cần ôn hôm nay</div>

                            @if (Model.FlashcardsDue is { Count: > 0 })
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (var card in Model.FlashcardsDue)
                                    {
                                        <li class="hj-vocab-item">
                                            <div>
                                                <div class="hj-vocab-kanji">@card.FrontText</div>
                                                @if (!string.IsNullOrEmpty(card.CourseTitle))
                                                {
                                                    <div class="hj-vocab-romaji">@card.CourseTitle</div>
                                                }
                                            </div>
                                            <div class="hj-vocab-meaning">@card.BackText</div>
                                        </li>
                                    }
                                </ul>
                                <a asp-area="Learner" asp-controller="Flashcard" asp-action="Review"
                                   class="btn-hj-primary w-100 d-block text-center mt-4">
                                    <i class="bi bi-stack me-2"></i>Ôn tập ngay
                                </a>
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <div style="font-size:32px;" class="mb-2">🎉</div>
                                    <p class="text-muted mb-0" style="font-size:14px;">Không có flashcard cần ôn hôm nay!</p>
                                </div>
                            }
                        </div>

                    </div>
                </div>
            }

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js" asp-append-version="true"></script>
</body>
</html>
