@model WebApplication1.Models.Authentication.RegisterStep1ViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hi Japan!</title>
    <link rel="icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await Html.PartialAsync("_RegisterStyle")
</head>
<body>
    <div class="register-wrapper">
        <div class="register-left">
            <div class="brand-logo">
                <span class="brand-badge">H</span>
                <span>Hi Japan!</span>
            </div>
            <h1 class="register-left-title">Bắt đầu hành trình của bạn!</h1>
            <p class="register-left-desc">Tạo tài khoản để trải nghiệm giáo trình độc quyền, lộ trình cá nhân hóa và cộng đồng học tiếng Nhật trên Hi Japan!.</p>
        </div>

        <div class="register-right">
            <form asp-controller="Register" asp-action="Init" method="post" class="register-form" novalidate>
                @Html.AntiForgeryToken()
                <h2>Bước 1: Tạo tài khoản</h2>
                <p class="subtitle">Điền thông tin bên dưới. Chúng tôi sẽ gửi mã OTP tới email để xác nhận.</p>

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert-register alert-register--error">
                        @foreach (var error in ViewData.ModelState.SelectMany(kv => kv.Value!.Errors))
                        {
                            @error.ErrorMessage
                            <br />
                        }
                    </div>
                }

                <div class="form-group">
                    <label asp-for="FullName">Họ và tên</label>
                    <input asp-for="FullName" class="form-control-custom" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" type="email" class="form-control-custom" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber">Số điện thoại</label>
                    <input asp-for="PhoneNumber" type="tel" class="form-control-custom" placeholder="0901 234 567" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="form-check-custom">
                    <input asp-for="Agree" />
                    <label asp-for="Agree">Tôi đồng ý với <a href="#" class="link-orange">Điều khoản</a> và <a href="#" class="link-orange">Chính sách bảo mật</a></label>
                    <span asp-validation-for="Agree" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-register">Gửi mã OTP</button>

                <p class="login-text">
                    Đã có tài khoản? <a asp-controller="Login" asp-action="Index" class="link-orange">Đăng nhập ngay</a>
                </p>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    @await Html.PartialAsync("_RegisterScript")
</body>
</html>
