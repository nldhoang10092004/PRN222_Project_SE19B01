@model CoreWeb.Areas.Learner.Models.CommunityIndexViewModel
@{
    ViewData["Title"] = "Cộng đồng - Hi Japan!";
    Layout = null;

    // ════════════════════════════════════════════════════════════
    // DỮ LIỆU DEMO — xoá block này khi kết nối DB thật
    // Thay bằng: @model CommunityIndexViewModel  + inject từ controller
    // ════════════════════════════════════════════════════════════
    // var demoUser = "Nguyễn Văn A";

    // Featured post
    var fp = new
    {
        Title = "Bí quyết tự học JLPT N3 trong 6 tháng cho người đi làm",
        Excerpt = "Làm thế nào để cân bằng giữa công việc bận rộn và việc học tiếng Nhật? Bài viết chia sẻ lộ trình chi tiết giúp bạn vượt qua kỳ thi JLPT N3 một cách nhẹ nhàng — từ cách chọn tài liệu đến quản lý thời gian hiệu quả.",
        Category = "Kinh nghiệm học",
        CatCss = "tag-experience",
        AuthorName = "Cô Nguyễn Thị Lan",
        AuthorRole = "Giáo viên Hi Japan!",
        AuthorInitial = "L",
        Date = "10 Thg 6, 2025",
        ReadMins = 8,
        Img = "https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?q=80&w=900&auto=format&fit=crop"
    };

    // Post grid
    var posts = new[] {
        new { Title="Khám phá văn hóa đền chùa dịp năm mới tại Nhật Bản",
              Excerpt="Hatsumoude là gì? Những quy tắc cần nhớ khi đến thăm đền thờ Thần đạo — từ trang phục đến cách cầu nguyện đúng chuẩn.",
              Category="Văn hóa", CatCss="tag-culture", Date="5 Thg 6, 2025", ReadMins=5,
              Img="https://images.unsplash.com/photo-1528164344705-47542687000d?q=80&w=900&auto=format&fit=crop" },
        new { Title="50 Từ vựng chủ đề ẩm thực Nhật Bản nhất định phải biết",
              Excerpt="Đi ăn nhà hàng Nhật không lo không biết gọi món với danh sách từ vựng thiết yếu này, kèm cách phát âm chuẩn.",
              Category="Từ vựng", CatCss="tag-vocab", Date="2 Thg 6, 2025", ReadMins=3,
              Img="https://images.unsplash.com/photo-1558865869-c93f6f8482af?q=80&w=900&auto=format&fit=crop" },
        new { Title="Cách viết Email tiếng Nhật chuẩn Business",
              Excerpt="Cấu trúc email chuẩn mực giúp bạn ghi điểm trong mắt đối tác Nhật — mẫu câu, kính ngữ và những lỗi hay gặp nhất.",
              Category="Công việc", CatCss="tag-business", Date="28 Thg 5, 2025", ReadMins=7,
              Img="https://images.unsplash.com/photo-1542051812-ba32e6c891a6?q=80&w=900&auto=format&fit=crop" },
        new { Title="Học Kanji theo bộ thủ — phương pháp hiệu quả nhất 2025",
              Excerpt="Thay vì học thuộc từng Kanji riêng lẻ, học theo bộ thủ giúp bạn nhớ lâu hơn và đoán nghĩa chữ mới chưa từng gặp.",
              Category="Kanji", CatCss="tag-kanji", Date="20 Thg 5, 2025", ReadMins=6,
              Img="https://images.unsplash.com/photo-1528360983277-13d401cdc186?q=80&w=900&auto=format&fit=crop" },
        new { Title="Ngữ pháp て-form: Ứng dụng thực tế trong hội thoại hàng ngày",
              Excerpt="て-form là cấu trúc quan trọng nhất tiếng Nhật. Bài viết giải thích 7 cách dùng phổ biến nhất kèm ví dụ thực tế dễ nhớ.",
              Category="Ngữ pháp", CatCss="tag-grammar", Date="15 Thg 5, 2025", ReadMins=5,
              Img="https://images.unsplash.com/photo-1542931287-023b922fa89b?q=80&w=900&auto=format&fit=crop" },
        new { Title="Chia sẻ kinh nghiệm thi JLPT N2 lần đầu — đậu hay rớt?",
              Excerpt="Tôi đã chuẩn bị 8 tháng cho kỳ thi N2. Đây là toàn bộ quá trình, sách tôi dùng, sai lầm tôi mắc và kết quả thực tế.",
              Category="Kinh nghiệm học", CatCss="tag-experience", Date="10 Thg 5, 2025", ReadMins=10,
              Img="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?q=80&w=900&auto=format&fit=crop" },
    };

    // Sidebar recent
    var recentPosts = new[] {
        new { Title="Bí quyết tự học JLPT N3 trong 6 tháng cho người đi làm", Date="10/6/2025", ReadMins=8 },
        new { Title="Khám phá văn hóa đền chùa dịp năm mới tại Nhật Bản",     Date="5/6/2025",  ReadMins=5 },
        new { Title="50 Từ vựng chủ đề ẩm thực Nhật Bản nhất định phải biết", Date="2/6/2025",  ReadMins=3 },
        new { Title="Học Kanji theo bộ thủ — phương pháp hiệu quả nhất 2025", Date="20/5/2025", ReadMins=6 },
        new { Title="Chia sẻ kinh nghiệm thi JLPT N2 lần đầu — đậu hay rớt?",Date="10/5/2025", ReadMins=10 },
    };
    // ════════════════════════════════════════════════════════════
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true">
    @await Html.PartialAsync("_BlogStyle")
</head>
<body>

    <!-- ═══ NAVBAR ═══ -->
    <nav class="hj-nav">
        <div class="container d-flex align-items-center justify-content-between">
            <a asp-area="Learner" asp-controller="Dashboard" asp-action="Index" class="hj-brand">
                <div class="hj-brand-dot">H</div>Hi Japan!
            </a>
            <ul class="d-none d-md-flex list-unstyled mb-0 gap-4">
                <li><a asp-area="Learner" asp-controller="Dashboard" asp-action="Index" class="hj-nav-link">Tổng quan</a></li>
                <li><a asp-area="Learner" asp-controller="Course" asp-action="Index" class="hj-nav-link">Khóa học</a></li>
                <li><a href="#" class="hj-nav-link">Tài liệu</a></li>
                <li><a asp-area="Learner" asp-controller="Blog" asp-action="Index" class="hj-nav-link active">Cộng đồng</a></li>
            </ul>
            <div class="d-flex align-items-center gap-3">
                <a href="#" class="text-muted fs-5 text-decoration-none"><i class="bi bi-bell"></i></a>
                <div class="dropdown">
                    <button class="btn p-0 border-0 dropdown-toggle" id="ddUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="hj-avatar">@(Model.FullName?.Substring(0, 1).ToUpper())</div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="ddUser">
                        <li><span class="dropdown-item-text fw-600 small text-muted px-3 pt-2">@Model.FullName</span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══ HERO ═══ -->
    <div class="hj-hero">
        <div class="hj-hero-kanji">読</div>
        <div class="container">
            <p class="mb-2" style="font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.6);">
                コミュニティ — Cộng đồng
            </p>
            <h1 style="font-family:'Outfit',sans-serif;font-size:34px;font-weight:800;color:#fff;margin-bottom:10px;">
                Góc chia sẻ Hi Japan!
            </h1>
            <p style="font-size:15px;color:rgba(255,255,255,.85);max-width:480px;line-height:1.65;margin:0;">
                Bí kíp học tập, văn hóa Nhật Bản, kinh nghiệm thi JLPT —
                được viết bởi giáo viên và cộng đồng học viên.
            </p>
        </div>
    </div>

    <!-- ═══ MAIN ═══ -->
    <main style="padding: 28px 0 72px;">
        <div class="container">
            <div class="row g-5">

                <!-- ── LEFT COLUMN ── -->
                <div class="col-lg-8">

                    <!-- Filter pills -->
                    <div class="hj-filter-bar fade-in">
                        <a href="#" class="hj-filter-pill active">Tất cả</a>
                        <a href="#" class="hj-filter-pill">Kinh nghiệm học</a>
                        <a href="#" class="hj-filter-pill">Văn hóa</a>
                        <a href="#" class="hj-filter-pill">Từ vựng</a>
                        <a href="#" class="hj-filter-pill">Ngữ pháp</a>
                        <a href="#" class="hj-filter-pill">Kanji</a>
                        <a href="#" class="hj-filter-pill">Công việc</a>
                    </div>

                    <!-- Featured post -->
                    <div class="hj-featured mt-4 mb-5 fade-in d1">
                        <div class="row g-0">
                            <div class="col-md-5">
                                <img src="@fp.Img" class="hj-featured-img" alt="@fp.Title">
                            </div>
                            <div class="col-md-7 d-flex flex-column justify-content-center p-4 p-lg-5">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="hj-tag @fp.CatCss">@fp.Category</span>
                                    <span class="text-muted" style="font-size:12px;">
                                        <i class="bi bi-calendar3 me-1"></i>@fp.Date
                                    </span>
                                </div>
                                <a href="#" class="hj-featured-title">@fp.Title</a>
                                <p style="font-size:14px;color:#6b7280;line-height:1.7;margin-bottom:20px;">@fp.Excerpt</p>
                                <div class="d-flex align-items-center justify-content-between mt-auto flex-wrap gap-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="hj-author-avatar">@fp.AuthorInitial</div>
                                        <div>
                                            <div style="font-size:13.5px;font-weight:600;">@fp.AuthorName</div>
                                            <div style="font-size:12px;color:#6b7280;">@fp.AuthorRole</div>
                                        </div>
                                    </div>
                                    <span class="hj-post-meta"><i class="bi bi-clock"></i> @fp.ReadMins phút đọc</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Post grid -->
                    <h2 class="hj-section-title fade-in d2">Bài viết mới nhất</h2>
                    <div class="row g-4">
                        @{
                            int di = 2;
                        }
                        @foreach (var p in posts)
                        {
                            <div class="col-md-6 fade-in d@(di)">
                                <div class="hj-post-card">
                                    <img src="@p.Img" class="hj-post-card-img" alt="@p.Title">
                                    <div class="p-4 d-flex flex-column flex-grow-1">
                                        <div class="mb-2">
                                            <span class="hj-tag @p.CatCss">@p.Category</span>
                                        </div>
                                        <a href="#" class="hj-post-card-title">@p.Title</a>
                                        <p style="font-size:13px;color:#6b7280;line-height:1.65;flex-grow:1;margin-bottom:16px;">
                                            @p.Excerpt
                                        </p>
                                        <div class="d-flex align-items-center justify-content-between">
                                            <span class="hj-post-meta">
                                                <i class="bi bi-clock"></i> @p.ReadMins phút · @p.Date
                                            </span>
                                            <a href="#" class="hj-read-more">Đọc tiếp <i class="bi bi-arrow-right"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            if (di < 6) di++;
                        }
                    </div>

                    <!-- Load more -->
                    <div class="text-center mt-5 fade-in">
                        <button class="btn-hj-outline">
                            <i class="bi bi-arrow-down me-2"></i>Tải thêm bài viết
                        </button>
                    </div>
                </div>

                <!-- ── RIGHT SIDEBAR ── -->
                <div class="col-lg-4">

                    <!-- Write CTA -->
                    <div class="hj-write-cta mb-4 fade-in d2">
                        <div style="font-family:'Outfit',sans-serif;font-size:17px;font-weight:700;margin-bottom:6px;">
                            Chia sẻ kinh nghiệm của bạn
                        </div>
                        <p style="font-size:13px;color:rgba(255,255,255,.82);line-height:1.6;margin-bottom:16px;">
                            Bạn có mẹo hay khi học tiếng Nhật? Viết bài và truyền cảm hứng cho cộng đồng Hi Japan!
                        </p>
                        <button class="btn-hj-light">✍️ Viết bài ngay</button>
                    </div>

                    <!-- Popular tags -->
                    <div class="hj-sidebar-card mb-4 fade-in d3">
                        <div class="hj-sidebar-title">Chủ đề phổ biến</div>
                        <div>
                            @foreach (var tag in new[] {
                                                        "JLPT N5","JLPT N4","JLPT N3","JLPT N2","JLPT N1",
                                                        "Kanji","Từ vựng","Ngữ pháp","Luyện nghe",
                                                        "Anime","Du học Nhật","Làm việc tại Nhật","Văn hóa"
                                                        })
                            {
                                <a href="#" class="hj-tag-pill">@tag</a>
                            }
                        </div>
                    </div>

                    <!-- Recent posts -->
                    <div class="hj-sidebar-card fade-in d4">
                        <div class="hj-sidebar-title">Bài viết gần đây</div>
                        <ul class="list-unstyled mb-0">
                            @foreach (var rp in recentPosts)
                            {
                                <li style="padding:10px 0;border-bottom:1px solid var(--color-border);">
                                    <a href="#"
                                       style="font-size:13.5px;font-weight:600;color:var(--color-text);text-decoration:none;line-height:1.4;display:block;margin-bottom:4px;"
                                       onmouseover="this.style.color='var(--color-primary)'"
                                       onmouseout="this.style.color='var(--color-text)'">
                                        @rp.Title
                                    </a>
                                    <span class="hj-post-meta">
                                        <i class="bi bi-clock"></i> @rp.ReadMins phút · @rp.Date
                                    </span>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js" asp-append-version="true"></script>
    <script>
        // Filter pills — active state (client-side, demo only)
        document.querySelectorAll('.hj-filter-pill').forEach(pill => {
            pill.addEventListener('click', e => {
                e.preventDefault();
                document.querySelectorAll('.hj-filter-pill').forEach(p => p.classList.remove('active'));
                pill.classList.add('active');
            });
        });
    </script>
</body>
</html>
