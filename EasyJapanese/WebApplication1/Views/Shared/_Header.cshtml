@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<header class="hj-header">
    <nav class="navbar navbar-expand-lg hj-navbar">
        <div class="container hj-nav-container">
            <a class="hj-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="hj-brand-icon">H</span>
                <span class="hj-brand-text">Hi Japan!</span>
            </a>

            <button class="navbar-toggler hj-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#hjNav"
                    aria-controls="hjNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse hj-nav-collapse" id="hjNav">
                <ul class="navbar-nav mx-auto hj-nav-links">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "Features" ? "active" : "")"
                           href="#features">Tính năng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#roadmap">Lộ trình</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#pricing">Bảng giá</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#blog">Blog</a>
                    </li>
                </ul>

                <div class="hj-nav-actions">
                    <a class="btn btn-outline-primary hj-btn-login" asp-area="" asp-controller="Login" asp-action="Login">Đăng nhập</a>
                    <a class="btn btn-primary hj-btn-start" href="#pricing">Bắt đầu miễn phí</a>
                </div>
            </div>
        </div>
    </nav>
</header>
