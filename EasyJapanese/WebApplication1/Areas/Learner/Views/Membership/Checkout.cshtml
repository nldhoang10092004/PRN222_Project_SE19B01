@model CoreLibrary.Data.Entities.SubscriptionPlan
@{
    ViewData["Title"] = "Thanh toán gói học";
    Layout = "_Layout";
}

@section Styles {
    <style>
        body { background-color: #f4f6f9; }
        .checkout-container {
            max-width: 900px;
            margin: 60px auto;
        }
        .checkout-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            overflow: hidden;
        }
        .checkout-header {
            background: var(--color-navy, #1A1A2E);
            color: #fff;
            padding: 30px;
            text-align: center;
        }
        .checkout-header h2 {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            margin: 0;
        }
        .plan-summary {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid #eaeaea;
        }
        .payment-method-box {
            border: 2px solid #eaeaea;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
        }
        .payment-method-box:hover {
            border-color: #d0d0d0;
        }
        .payment-method-box.active {
            border-color: var(--color-primary);
            background-color: rgba(200,16,46,0.02);
        }
        .payment-logo {
            width: 40px;
            height: 40px;
            object-fit: contain;
            margin-right: 15px;
        }
    </style>
}

<div class="container checkout-container">
    <div class="checkout-card">
        <div class="checkout-header">
            <h2>Xác nhận thanh toán</h2>
            <p class="text-white-50 mb-0 mt-2">Hoàn tất để kích hoạt tài khoản VIP của bạn</p>
        </div>
        
        <div class="p-4 p-md-5">
            <form asp-action="ProcessCheckout" method="post">
                <input type="hidden" name="planId" value="@Model.PlanId" />
                <input type="hidden" name="paymentMethod" id="paymentMethodInput" value="vnpay" />

                <div class="row g-5">
                    <div class="col-md-6">
                        <h4 class="mb-4" style="font-family: 'Outfit', sans-serif; font-weight: 700;">Phương thức thanh toán</h4>
                        
                        <div class="payment-method-box active" onclick="selectPayment('vnpay', this)">
                            <img src="https://vnpay.vn/s1/statics.vnpay.vn/2023/9/06ncktiwd6dc1694418189387.png" alt="VNPay" class="payment-logo">
                            <div>
                                <div class="fw-bold">Thanh toán qua VNPAY</div>
                                <div class="text-muted small">ATM / Internet Banking</div>
                            </div>
                            <i class="bi bi-check-circle-fill ms-auto text-primary" style="font-size: 1.2rem; display: block;"></i>
                        </div>

                        <div class="payment-method-box" onclick="selectPayment('momo', this)">
                            <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" alt="Momo" class="payment-logo">
                            <div>
                                <div class="fw-bold">Thanh toán qua MoMo</div>
                                <div class="text-muted small">Ví điện tử MoMo</div>
                            </div>
                            <i class="bi bi-check-circle-fill ms-auto text-primary check-icon" style="font-size: 1.2rem; display: none;"></i>
                        </div>
                        
                        <div class="alert alert-warning mt-4">
                            <strong>Lưu ý (Mock):</strong> Đây là giao diện giả lập. Bấm xác nhận sẽ kích hoạt tài khoản trực tiếp mà không trừ tiền.
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h4 class="mb-4" style="font-family: 'Outfit', sans-serif; font-weight: 700;">Đơn hàng của bạn</h4>
                        
                        <div class="plan-summary">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fs-5 fw-bold">@Model.PlanName</span>
                                <span class="fs-5 text-primary fw-bold">@Model.Price.ToString("N0")đ</span>
                            </div>
                            <div class="d-flex justify-content-between text-muted mb-3 border-bottom pb-3">
                                <span>Thời hạn sử dụng</span>
                                <span>@Model.DurationDays ngày</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fw-bold fs-5">Tổng thanh toán</span>
                                <span class="fs-3 text-danger fw-bold" style="font-family: 'Outfit', sans-serif;">@Model.Price.ToString("N0")đ</span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3" style="background-color: var(--color-primary); border: none; font-weight: 600; font-size: 1.1rem; border-radius: 50px;">
                            Xác nhận thanh toán
                        </button>
                        
                        <div class="text-center mt-3">
                            <a asp-action="Plans" class="text-muted text-decoration-none"><i class="bi bi-arrow-left"></i> Quay lại chọn gói</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectPayment(method, element) {
            document.getElementById('paymentMethodInput').value = method;
            
            var boxes = document.querySelectorAll('.payment-method-box');
            boxes.forEach(b => {
                b.classList.remove('active');
                var icon = b.querySelector('.bi-check-circle-fill');
                if(icon) icon.style.display = 'none';
            });
            
            element.classList.add('active');
            var icon = element.querySelector('.bi-check-circle-fill');
            if(icon) icon.style.display = 'block';
        }
    </script>
}
