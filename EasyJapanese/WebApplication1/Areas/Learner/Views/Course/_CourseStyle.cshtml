        font-weight: 700;
        margin-bottom: 1rem;
        align-self: flex-start;
        background: #eef4ff;
        color: #3b82f6;
    }

    .course-name {
        font-size: 1.25rem;
        font-weight: 800;
        font-family: 'Outfit', sans-serif;
        margin-bottom: 0.5rem;
        color: #222;
    }

    .course-desc {
        font-size: 0.85rem;
        color: #666;
        line-height: 1.5;
        margin-bottom: 0;
        flex: 1;
    }

    /* Used only in Detail View left panel */
    .course-stats {
        display: flex;
        justify-content: space-between;
        border-top: 1px dashed #eaeaea;
        border-bottom: 1px dashed #eaeaea;
        padding: 1rem 0;
        margin: 1.5rem 0;
    }
    .stat-item {
        text-align: center;
        flex: 1;
        border-right: 1px solid #eaeaea;
    }
    .stat-item:last-child {
        border-right: none;
    }
    .stat-val {
        font-size: 1.1rem;
        font-weight: 800;
        font-family: 'Outfit', sans-serif;
        color: #222;
    }
    .stat-lbl {
        font-size: 0.7rem;
        color: #888;
        margin-top: 2px;
    }

    /* Dotted divider for Course List cards */
    .teacher-divider {
        border-top: 1px dashed #eaeaea;
        margin: 1.5rem 0;
    }

    .course-teacher {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .teacher-avt {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
    }

    .teacher-name {
        font-weight: 700;
        font-size: 0.85rem;
        color: #333;
        line-height: 1.2;
    }

    .teacher-exp {
        font-size: 0.7rem;
        color: #888;
        margin-top: 2px;
    }

    /* Outline Button for Course List */
    .btn-vao-hoc {
        display: block;
        width: 100%;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        border: 1.5px solid #e64a51;
        color: #e64a51;
        font-weight: 600;
        font-size: 0.9rem;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
        background: transparent;
    }

    .btn-vao-hoc:hover {
        background: #e64a51;
        color: #fff;
    }
</style>
