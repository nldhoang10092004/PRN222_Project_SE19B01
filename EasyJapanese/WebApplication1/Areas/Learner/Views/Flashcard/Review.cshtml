@{
    ViewData["Title"] = "Ôn tập Flashcard";
    Layout = "_Layout";
}

<div class="container py-5 text-center mt-5" style="background-color: #f4f6f9; min-height: 60vh;">
    <i class="bi bi-stack" style="font-size: 5rem; color: var(--color-primary);"></i>
    <h2 class="mt-4" style="font-family: 'Outfit', sans-serif; font-weight: 700;">Tính năng ôn tập đang được cập nhật</h2>
    <p class="text-muted mb-4">Giao diện học Flashcard sẽ sớm được hoàn thiện.</p>
    <a asp-area="Learner" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary px-4 py-2" style="border-radius: 50px;">Quay lại Dashboard</a>
</div>
