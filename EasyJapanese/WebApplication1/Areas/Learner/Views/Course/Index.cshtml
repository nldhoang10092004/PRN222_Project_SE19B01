@model IEnumerable<CoreLibrary.Data.Entities.Course>
@{
    ViewData["Title"] = "Danh Sách Khóa Học";
}

@section Styles {
    @await Html.PartialAsync("_CourseStyle")
}

<div class="hj-content container py-5" style="max-width: 1100px;">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="course-list-title mb-2">Danh Sách Khóa Học</h1>
        <p class="course-list-subtitle">Lựa chọn khóa học phù hợp với mục tiêu của bạn. Không giới hạn cấp độ.</p>
    </div>

    <!-- Course Grid -->
    <div class="row g-4 justify-content-center">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                var levelClass = course.Level?.LevelName?.ToLower() ?? "n5";
                var levelText = course.Level?.LevelName ?? "Beginner";
                
                <div class="col-md-4">
                    <div class="course-card">
                        <div class="course-cover @(levelClass == "n5" ? "bg-red" : "")">
                            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&h=400&fit=crop" alt="@course.Title" />
                        </div>
                        <div class="course-body">
                            <span class="badge-level @levelClass">@levelText</span>
                            <h3 class="course-name">@course.Title</h3>
                            <p class="course-desc">@course.Description</p>
                            
                            <div class="teacher-divider"></div>

                            <div class="course-teacher">
                                <img src="@(course.Mentor?.AvatarUrl ?? "https://i.pravatar.cc/100?img=5")" alt="Avatar" class="teacher-avt" />
                                <div class="teacher-info">
                                    <div class="teacher-name">@(course.Mentor?.FullName ?? "Đang cập nhật")</div>
                                    <div class="teacher-exp">@(course.Mentor?.Expertise ?? "Giảng viên EasyJapanese")</div>
                                </div>
                            </div>

                            <a href="/learn/Course/Detail/@course.CourseId" class="btn-vao-hoc mt-4">Vào học ngay</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-3">Hiện chưa có khóa học nào. Vui lòng quay lại sau!</p>
            </div>
        }
    </div>
</div>
