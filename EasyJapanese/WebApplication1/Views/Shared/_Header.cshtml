@using CoreLibrary.Authentication
@using CoreLibrary.Utility
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentUser = HttpContextAccessor.HttpContext?.Session.GetObject<CurrentUser>(IAuthenticationService.SessionKeyCurrentUser);
}
<!-- ═══ NAVBAR ═══ -->
<nav class="hj-nav" style="background-color: #fff; border-bottom: 1px solid #eaeaea; padding: 1rem 0;">
    <div class="container d-flex align-items-center justify-content-between">
        <a href="@((currentUser != null) ? "/learn/dashboard" : "/")" class="hj-brand" style="text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
            <div class="hj-brand-dot" style="width: 32px; height: 32px; border-radius: 8px; background: #e64a51; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem;">H</div>
            <span style="font-size: 1.25rem; font-weight: 800; color: #e64a51; font-family: 'Outfit', sans-serif;">Hi Japan!</span>
        </a>

        <ul class="d-none d-md-flex list-unstyled mb-0 gap-4" style="margin: 0; padding: 0;">
            <li><a href="/learn/dashboard" class="hj-nav-link @(currentController == "Dashboard" ? "active" : "")" style="text-decoration: none; color: #666; font-weight: 500;">Tổng quan</a></li>
            <li><a href="/learn/Course" class="hj-nav-link @(currentController == "Course" ? "active" : "")" style="text-decoration: none; color: #666; font-weight: 500;">Khóa học</a></li>
            <li><a href="#" class="hj-nav-link" style="text-decoration: none; color: #666; font-weight: 500;">Tài liệu</a></li>
            <li><a href="#" class="hj-nav-link" style="text-decoration: none; color: #666; font-weight: 500;">Cộng đồng</a></li>
        </ul>

        <div class="d-flex align-items-center gap-3">
            @if (currentUser == null)
            {
                <a class="btn btn-outline-danger" href="/Login" style="border-radius: 20px; padding: 0.375rem 1.25rem; font-weight: 600;">Đăng nhập</a>
                <a class="btn btn-danger" href="/#pricing" style="border-radius: 20px; padding: 0.375rem 1.25rem; font-weight: 600; background-color: #e64a51; border-color: #e64a51;">Bắt đầu miễn phí</a>
            }
            else
            {
                <a href="/admin" class="text-muted d-none d-lg-inline text-decoration-none" style="font-size: 0.9rem;">Khu vực quản trị</a>
                <a href="#" class="text-muted fs-5 text-decoration-none ms-2"><i class="bi bi-bell"></i></a>
                <div class="dropdown">
                    <button class="btn p-0 border-0 dropdown-toggle" id="ddUser" data-bs-toggle="dropdown" aria-expanded="false" style="display: flex; align-items: center; gap: 0.5rem;">
                        <div class="hj-avatar" style="width: 36px; height: 36px; border-radius: 50%; background: #1e3c72; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                            @((currentUser.FullName ?? currentUser.Email).Substring(0, 1).ToUpper())
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="ddUser">
                        <li><span class="dropdown-item-text fw-bold text-dark px-3 pt-2">@(currentUser.FullName ?? currentUser.Email)</span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2 text-muted"></i>Tài khoản</a></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2 text-muted"></i>Cài đặt</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-area="" asp-controller="Login" asp-action="Logout" method="post" class="m-0 p-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </div>
</nav>
