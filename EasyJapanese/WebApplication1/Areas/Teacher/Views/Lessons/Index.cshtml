@model IEnumerable<CoreLibrary.Data.Entities.Lesson>
@{
    ViewData["Title"] = "Quản lý Bài giảng";
    var courseId = ViewData["CourseId"];
    var courseTitle = ViewData["CourseTitle"];
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
        <a href="/teacher/courses" class="text-decoration-none text-muted mb-2 d-inline-block"><i class="bi bi-arrow-left"></i> Khóa học của tôi</a>
        <h3 class="fw-bold mb-0" style="font-family: 'Outfit', sans-serif; color: var(--color-navy);">Bài giảng: @courseTitle</h3>
    </div>
    <a href="/teacher/lessons/create?courseId=@courseId" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Thêm Bài giảng</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width: 80px;">Thứ tự</th>
                        <th>Tiêu đề</th>
                        <th>Loại bài giảng</th>
                        <th>Thời lượng</th>
                        <th>Xem trước</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">@item.SortOrder</td>
                            <td>
                                <div class="fw-bold text-dark">@item.Title</div>
                            </td>
                            <td>
                                @if (item.LessonType == "Video")
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary"><i class="bi bi-play-circle-fill me-1"></i> Video</span>
                                }
                                else if (item.LessonType == "Text")
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-file-text-fill me-1"></i> Văn bản</span>
                                }
                                else
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info">@item.LessonType</span>
                                }
                            </td>
                            <td>@(item.Duration.HasValue ? $"{item.Duration} phút" : "-")</td>
                            <td>
                                @if (item.IsPreview)
                                {
                                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted fs-5"></i>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a href="#" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil-square"></i> Sửa</a>
                                <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-camera-video fs-1 d-block mb-3"></i>
                                Khóa học này chưa có bài giảng nào. Hãy bấm "Thêm Bài giảng" để bắt đầu!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
