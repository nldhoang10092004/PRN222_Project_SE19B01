@{
    ViewData["Title"] = "Danh Sách Khóa Học";
}

@section Styles {
    @await Html.PartialAsync("_CourseStyle")
}

<div class="hj-content container py-5" style="max-width: 1100px;">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="course-list-title mb-2">Danh Sách Khóa Học</h1>
        <p class="course-list-subtitle">Lựa chọn khóa học phù hợp với mục tiêu của bạn. Không giới hạn cấp độ.</p>
    </div>

    <!-- Course Grid -->
    <div class="row g-4 justify-content-center">
        <!-- N5 Course -->
        <div class="col-md-4">
            <div class="course-card">
                <div class="course-cover bg-red">
                    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&h=400&fit=crop" alt="Khóa học N5" />
                </div>
                <div class="course-body">
                    <span class="badge-level n5">N5 Beginner</span>
                    <h3 class="course-name">Khóa học tiếng Nhật N5</h3>
                    <p class="course-desc">Khóa học nhập môn dành cho người mới bắt đầu. Nắm vững bảng chữ cái và ngữ pháp cơ bản.</p>
                    
                    <div class="teacher-divider"></div>

                    <div class="course-teacher">
                        <img src="https://i.pravatar.cc/100?img=5" alt="Avatar" class="teacher-avt" />
                        <div class="teacher-info">
                            <div class="teacher-name">Cô Nguyễn Thị A</div>
                            <div class="teacher-exp">Giáo viên kinh nghiệm 5 năm</div>
                        </div>
                    </div>

                    <a href="/learn/Course/Detail/1" class="btn-vao-hoc mt-4">Vào học ngay</a>
                </div>
            </div>
        </div>

        <!-- N4 Course -->
        <div class="col-md-4">
            <div class="course-card">
                <div class="course-cover">
                    <img src="https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=600&h=400&fit=crop" alt="Khóa học N4" />
                </div>
                <div class="course-body">
                    <span class="badge-level n4">N4 Pre-Intermediate</span>
                    <h3 class="course-name">Khóa học tiếng Nhật N4</h3>
                    <p class="course-desc">Nâng cao khả năng giao tiếp và vốn từ vựng. Chuẩn bị nền tảng vững chắc cho N3.</p>
                    
                    <div class="teacher-divider"></div>

                    <div class="course-teacher">
                        <img src="https://i.pravatar.cc/100?img=11" alt="Avatar" class="teacher-avt" />
                        <div class="teacher-info">
                            <div class="teacher-name">Thầy Trần Văn B</div>
                            <div class="teacher-exp">Cựu du học sinh Nhật Bản</div>
                        </div>
                    </div>

                    <a href="/learn/Course/Detail/2" class="btn-vao-hoc mt-4">Vào học ngay</a>
                </div>
            </div>
        </div>

        <!-- N3 Course -->
        <div class="col-md-4">
            <div class="course-card">
                <div class="course-cover">
                    <img src="https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=600&h=400&fit=crop" alt="Khóa học N3" />
                </div>
                <div class="course-body">
                    <span class="badge-level n3">N3 Intermediate</span>
                    <h3 class="course-name">Khóa học tiếng Nhật N3</h3>
                    <p class="course-desc">Khóa học trọng tâm giao tiếp kinh doanh và đọc hiểu báo chí Nhật Bản.</p>
                    
                    <div class="teacher-divider"></div>

                    <div class="course-teacher">
                        <img src="https://i.pravatar.cc/100?img=9" alt="Avatar" class="teacher-avt" />
                        <div class="teacher-info">
                            <div class="teacher-name">Cô Lê Thị C</div>
                            <div class="teacher-exp">Chuyên gia đào tạo N3, N2</div>
                        </div>
                    </div>

                    <a href="/learn/Course/Detail/3" class="btn-vao-hoc mt-4">Vào học ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>
