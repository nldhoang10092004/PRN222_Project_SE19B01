@model CoreLibrary.Data.Entities.Course
@{
    ViewData["Title"] = "Tạo khóa học mới";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
        <a href="/teacher/courses" class="text-decoration-none text-muted mb-2 d-inline-block"><i class="bi bi-arrow-left"></i> Quay lại</a>
        <h3 class="fw-bold mb-0" style="font-family: 'Outfit', sans-serif; color: var(--color-navy);">Tạo khóa học mới</h3>
    </div>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold">Tên khóa học <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control form-control-lg" placeholder="Ví dụ: Luyện thi JLPT N3 Chuyên Sâu" required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="LevelId" class="form-label fw-bold">Cấp độ (JLPT) <span class="text-danger">*</span></label>
                            <select asp-for="LevelId" class="form-select form-select-lg" asp-items="ViewBag.LevelId" required>
                                <option value="">-- Chọn cấp độ --</option>
                            </select>
                            <span asp-validation-for="LevelId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsFree" class="form-label fw-bold">Loại khóa học</label>
                            <select asp-for="IsFree" class="form-select form-select-lg">
                                <option value="true">Miễn phí</option>
                                <option value="false">Có phí (Yêu cầu Gói Subscription)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả khóa học</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Giới thiệu nội dung, đối tượng học viên..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-5">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Tạo khóa học</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
