@model WebApplication1.Models.Authentication.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập quản trị";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hi Japan! Admin</title>
    <link rel="icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await Html.PartialAsync("_LoginStyle")
</head>
<body>
    <div class="login-wrapper">
        <div class="login-left">
            <div class="brand-logo">
                <span class="brand-badge">A</span>
                <span>Hi Japan! Admin</span>
            </div>
            <h1 class="login-left-title">Khu vực quản trị</h1>
            <p class="login-left-desc">Đăng nhập để quản lý người dùng, khóa học và vận hành hệ thống Hi Japan!.</p>
        </div>

        <div class="login-right">
            <form asp-controller="AdminLogin" asp-action="Index" asp-route-area="Admin" method="post" class="login-form" novalidate>
                @Html.AntiForgeryToken()
                <h2>Đăng nhập quản trị</h2>
                <p class="subtitle">Chỉ tài khoản Admin mới có quyền truy cập.</p>

                @if (TempData["FlashMessage"] is string flash)
                {
                    <div class="alert-login alert-login--success">@flash</div>
                }

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert-login alert-login--error">
                        @foreach (var error in ViewData.ModelState.SelectMany(kv => kv.Value!.Errors))
                        {
                            @error.ErrorMessage
                            <br />
                        }
                    </div>
                }

                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" class="form-control-custom" placeholder="admin@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <div class="form-row-flex">
                        <label asp-for="Password">Mật khẩu</label>
                        <a href="#" class="link-blue">Quên mật khẩu?</a>
                    </div>
                    <input asp-for="Password" class="form-control-custom" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-check-custom">
                    <input asp-for="Remember" />
                    <label asp-for="Remember">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn-login">Đăng nhập</button>

                <p class="signup-text">
                    Quay lại trang <a href="/" class="link-blue">Hi Japan!</a>
                </p>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    @await Html.PartialAsync("_LoginScript")
</body>
</html>
